#!/bin/bash
# S2I assemble script for the merchantservices.web.tools Angular SPA.
#
# The Red Hat nodejs s2i image's DEFAULT assemble only runs `npm install` — it
# does NOT build the Angular bundle, and `dist/` is gitignored so it is never
# present in the cloned source. Without this script the runtime `npm start`
# (npx serve -s dist/...) would have nothing to serve. This script guarantees
# the production build runs during the s2i build phase.
set -e

echo "=== s2i assemble: merchantservices.web.tools ==="

# Install ALL dependencies (including devDependencies) — the Angular CLI and
# build toolchain live in devDependencies, so we must not skip them.
echo "=== Installing dependencies (including devDependencies) ==="
npm install

echo "=== Building Angular production bundle ==="
npm run build

echo "=== s2i assemble complete ==="